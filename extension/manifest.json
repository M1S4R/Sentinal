{
  "manifest_version": 3,
  "name": "Live Threat Intelligence Extension",
  "version": "1.0",
  "description": "Threat Intelligence Browser Extension",

  "permissions": [
    "tabs",
    "activeTab",
    "notifications",
    "storage",
    "scripting"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background/background.js"
  },

  "action": {
    "default_popup": "popup/popup.html"
  }
}